# Copy to .env and fill in values
LOPEN_ENV=development
LOPEN_LOG_LEVEL=INFO
LOPEN_LLM_MODEL_PATH=models/llm/model.gguf
LOPEN_WHISPER_BINARY=
LOPEN_PIPER_BINARY=
LOPEN_LLAMA_BINARY=
LOPEN_DASHBOARD_SECRET_KEY=change-this-secret-key
# WhatsApp (optional)
LOPEN_WHATSAPP_ENABLED=false
# SSH API (optional — for remote access from MacBook Air)
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
LOPEN_SSH_API_KEY=
# Notion integration (optional — for student workflow features)
# 1. Create integration at https://www.notion.so/my-integrations
# 2. Share your databases with the integration
# 3. Copy the integration token and database IDs below
NOTION_TOKEN=
NOTION_ASSIGNMENTS_DB=
NOTION_NOTES_DB=
